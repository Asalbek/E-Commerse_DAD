{
  "title": "FlashCart Overview",
  "tags": ["flashcart"],
  "timezone": "browser",
  "panels": [
    {
      "type": "timeseries",
      "title": "Total API Requests",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (method, endpoint)",
          "legendFormat": "{{method}} {{endpoint}}",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "type": "logs",
      "title": "Recent Application Logs",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "{job=\"containerlogs\"}",
          "refId": "A"
        }
      ],
      "datasource": "Loki",
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true
      }
    }
  ],
  "schemaVersion": 36,
  "version": 1
}
